{
  "name": "armin",
  "productName": "Armin",
  "desktopName": "armin.desktop",
  "version": "0.3.1-alpha",
  "description": "Local-first hierarchical spaced-repetition flashcards for desktop.",
  "main": ".vite/build/main.js",
  "private": true,
  "homepage": "https://github.com/ansanabria/armin#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ansanabria/armin.git"
  },
  "bugs": {
    "url": "https://github.com/ansanabria/armin/issues"
  },
  "scripts": {
    "native:node": "npm rebuild better-sqlite3",
    "native:electron": "electron-rebuild -f -w better-sqlite3",
    "prestart": "npm run native:electron",
    "start": "electron-forge start",
    "prepackage": "npm run native:electron",
    "package": "electron-forge package",
    "premake": "npm run native:electron",
    "make": "electron-forge make",
    "prepublish": "npm run native:electron",
    "publish": "node scripts/publish.mjs",
    "premcp": "npm run native:node",
    "mcp": "tsx src/mcp/server.ts",
    "typecheck": "tsc --noEmit",
    "pretest": "npm run native:node",
    "test": "vitest run",
    "pretest:mcp": "npm run native:node",
    "test:mcp": "vitest run --config vitest.mcp.config.ts",
    "pretest:e2e": "npm run native:electron",
    "test:e2e": "playwright test",
    "pretest:e2e:headed": "npm run native:electron",
    "test:e2e:headed": "playwright test --headed",
    "pretest:e2e:build": "npm run native:electron",
    "test:e2e:build": "electron-forge package",
    "check:package": "node scripts/check-package.mjs",
    "prebench:deck": "npm run native:node",
    "bench:deck": "tsx scripts/benchmark-deck-load.ts",
    "bench:graph": "tsx scripts/benchmark-graph-flow.ts",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "icons": "node scripts/build-logo-svg.mjs && node scripts/generate-icons.mjs"
  },
  "keywords": [
    "electron",
    "flashcards",
    "local-first",
    "spaced-repetition"
  ],
  "author": {
    "name": "Andy Spike",
    "email": "ansanabria@proton.me"
  },
  "license": "MIT",
  "devDependencies": {
    "@electron-forge/cli": "^7.11.2",
    "@electron-forge/maker-squirrel": "^7.11.2",
    "@electron-forge/maker-zip": "^7.11.2",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.2",
    "@electron-forge/plugin-fuses": "^7.11.2",
    "@electron-forge/plugin-vite": "^7.11.2",
    "@electron-forge/publisher-github": "^7.11.2",
    "@electron/asar": "^3.4.1",
    "@electron/fuses": "^1.8.0",
    "@playwright/test": "^1.58.2",
    "@reforged/maker-appimage": "^5.2.0",
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/vite": "^4.3.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/dagre": "^0.7.54",
    "@types/electron-squirrel-startup": "^1.0.2",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "drizzle-kit": "^0.31.10",
    "electron": "41.7.2",
    "electron-devtools-installer": "^4.0.0",
    "opentype.js": "^2.0.0",
    "png-to-ico": "^3.0.1",
    "png2icons": "^2.0.1",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.4",
    "vite": "^5.4.21",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@dagrejs/dagre": "^3.0.0",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource-variable/source-serif-4": "^5.2.9",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-router": "^1.170.11",
    "@tiptap/core": "^3.26.0",
    "@tiptap/extension-image": "^3.26.0",
    "@tiptap/extension-placeholder": "^3.26.0",
    "@tiptap/markdown": "^3.26.0",
    "@tiptap/pm": "^3.26.0",
    "@tiptap/react": "^3.26.0",
    "@tiptap/starter-kit": "^3.26.0",
    "@xyflow/react": "^12.11.0",
    "better-sqlite3": "^12.10.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "electron-squirrel-startup": "^1.0.1",
    "fflate": "^0.8.3",
    "fzstd": "^0.1.1",
    "lucide-react": "^1.17.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.6.0",
    "ts-fsrs": "^5.4.1",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  }
}
