{
  "name": "armin",
  "productName": "Armin",
  "desktopName": "armin.desktop",
  "version": "0.1.0-alpha.1",
  "description": "Local-first hierarchical spaced-repetition flashcards for desktop.",
  "main": ".vite/build/main.js",
  "private": true,
  "homepage": "https://github.com/ansanabria/armin#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ansanabria/armin.git"
  },
  "bugs": {
    "url": "https://github.com/ansanabria/armin/issues"
  },
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "publish": "node scripts/publish.mjs",
    "electron:install": "node scripts/ensure-electron.mjs",
    "mcp": "tsx src/mcp/server.ts",
    "lint": "eslint --ext .ts,.tsx .",
    "test": "vitest run",
    "test:mcp": "vitest run --config vitest.mcp.config.ts",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:build": "electron-forge package",
    "bench:deck": "tsx scripts/benchmark-deck-load.ts",
    "format": "prettier --write .",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "icons": "node scripts/build-logo-svg.mjs && node scripts/generate-icons.mjs"
  },
  "keywords": [
    "electron",
    "flashcards",
    "local-first",
    "spaced-repetition"
  ],
  "author": {
    "name": "Andy Spike",
    "email": "ansanabria@proton.me"
  },
  "license": "MIT",
  "devDependencies": {
    "@electron-forge/cli": "^7.11.2",
    "@electron-forge/maker-deb": "^7.11.2",
    "@electron-forge/maker-rpm": "^7.11.2",
    "@electron-forge/maker-squirrel": "^7.11.2",
    "@electron-forge/maker-zip": "^7.11.2",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.2",
    "@electron-forge/plugin-fuses": "^7.11.2",
    "@electron-forge/plugin-vite": "^7.11.2",
    "@electron-forge/publisher-github": "^7.11.2",
    "@electron/fuses": "^1.8.0",
    "@playwright/test": "^1.58.2",
    "@reforged/maker-appimage": "^5.2.0",
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/vite": "^4.3.0",
    "@types/dagre": "^0.7.54",
    "@types/electron-squirrel-startup": "^1.0.2",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "@vitejs/plugin-react": "^5.2.0",
    "drizzle-kit": "^0.31.10",
    "electron": "^42.3.3",
    "eslint": "^8.57.1",
    "eslint-plugin-import": "^2.32.0",
    "opentype.js": "^2.0.0",
    "png-to-ico": "^3.0.1",
    "png2icons": "^2.0.1",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vite": "^5.4.21",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@dagrejs/dagre": "^3.0.0",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource-variable/source-serif-4": "^5.2.9",
    "@libsql/client": "^0.17.3",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-router": "^1.170.11",
    "@tiptap/core": "^3.26.0",
    "@tiptap/extension-image": "^3.26.0",
    "@tiptap/extension-placeholder": "^3.26.0",
    "@tiptap/markdown": "^3.26.0",
    "@tiptap/pm": "^3.26.0",
    "@tiptap/react": "^3.26.0",
    "@tiptap/starter-kit": "^3.26.0",
    "@xyflow/react": "^12.11.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "electron-squirrel-startup": "^1.0.1",
    "fflate": "^0.8.3",
    "fzstd": "^0.1.1",
    "lucide-react": "^1.17.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.6.0",
    "ts-fsrs": "^5.4.1",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "allowScripts": {
    "electron-winstaller@5.4.0": true,
    "esbuild@0.21.5": true,
    "better-sqlite3@12.10.0": true,
    "esbuild@0.18.20": true,
    "esbuild@0.25.12": true,
    "esbuild@0.28.0": true
  }
}
