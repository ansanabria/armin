{
  "name": "armin-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Monorepo for Armin: the local-first desktop app and its optional cloud sync service.",
  "homepage": "https://github.com/ansanabria/armin#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ansanabria/armin.git"
  },
  "bugs": {
    "url": "https://github.com/ansanabria/armin/issues"
  },
  "license": "MIT",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "start": "npm run start --workspace apps/desktop --",
    "package": "npm run package --workspace apps/desktop --",
    "make": "npm run make --workspace apps/desktop --",
    "publish": "npm run publish --workspace apps/desktop --",
    "mcp": "npm run mcp --workspace apps/desktop --",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspace apps/desktop --",
    "test:mcp": "npm run test:mcp --workspace apps/desktop --",
    "test:e2e": "npm run test:e2e --workspace apps/desktop --",
    "test:e2e:headed": "npm run test:e2e:headed --workspace apps/desktop --",
    "test:e2e:build": "npm run test:e2e:build --workspace apps/desktop --",
    "bench:deck": "npm run bench:deck --workspace apps/desktop --",
    "db:generate": "npm run db:generate --workspace apps/desktop --",
    "db:studio": "npm run db:studio --workspace apps/desktop --",
    "icons": "npm run icons --workspace apps/desktop --",
    "lint": "eslint --ext .ts,.tsx .",
    "format": "prettier --write ."
  },
  "overrides": {
    "@electron/rebuild": "4.0.4",
    "yauzl": "^3.3.1"
  },
  "allowScripts": {
    "electron-winstaller@5.4.0": true,
    "esbuild@0.21.5": true,
    "better-sqlite3@12.10.1": true,
    "electron@41.7.2": true,
    "esbuild@0.18.20": true,
    "esbuild@0.25.12": true,
    "esbuild@0.28.0": true
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "eslint": "^8.57.1",
    "eslint-plugin-import": "^2.32.0",
    "prettier": "^3.8.3",
    "typescript": "^5.9.3"
  }
}
